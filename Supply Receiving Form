// ==================== MONDAY.COM BOARD CONFIG ====================
// These get auto-detected on login
let BOARD_ID = null;
let BOARD_COLUMNS = {};  // Maps our field names to Monday column IDs
let boardReady = false;

// Column definitions we need on the board
// Each item submitted becomes a row; these are the columns:
const REQUIRED_COLUMNS = [
  { key: 'supplier',        title: 'Supplier',         type: 'text' },
  { key: 'po_number',       title: 'PO / Reference #', type: 'text' },
  { key: 'delivery_date',   title: 'Delivery Date',    type: 'date' },
  { key: 'delivery_method', title: 'Delivery Method',  type: 'text' },
  { key: 'quantity',        title: 'Quantity',          type: 'numbers' },
  { key: 'unit',            title: 'Unit',              type: 'text' },
  { key: 'condition',       title: 'Condition',         type: 'status' },
  { key: 'notes',           title: 'Notes',             type: 'long_text' },
  { key: 'received_by',     title: 'Received By',       type: 'text' },
  { key: 'received_at',     title: 'Received At',       type: 'text' },
  { key: 'receipt_id',      title: 'Receipt ID',        type: 'text' }
];

// ==================== STATE ====================
let currentOperator = null;
let receiptItems = [];
let sessionReceipts = [];
let receiptCounter = 0;

// ==================== MONDAY API ====================
async function mondayQuery(query, variables) {
  const res = await fetch(MONDAY_API, {
    method: 'POST',
    headers: {
      'Authorization': MONDAY_TOKEN,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ query, variables })
  });
  return res.json();
}

// Find the "Vital Supplies" board
async function findBoard() {
  setStatus('loading', 'Connecting to Monday.com...');

  try {
    const result = await mondayQuery(`{ boards(limit: 100) { id name } }`);
    const boards = result.data.boards;

    // Search for "Vital Supplies" board (case-insensitive, partial match)
    const board = boards.find(b =>
      b.name.toLowerCase().includes('vital supplies') ||
      b.name.toLowerCase().includes('vital supply')
    );

    if (!board) {
      console.warn('Vital Supplies board not found. Available boards:', boards.map(b => b.name));
      setStatus('error', 'Board "Vital Supplies" not found on Monday.com');
      showToast('Could not find Vital Supplies board. Check Monday.com.');
      return false;
    }

    BOARD_ID = board.id;
    console.log(`Found board: "${board.name}" (ID: ${BOARD_ID})`);

    return true;
  } catch (err) {
    console.error('Error finding board:', err);
    setStatus('error', 'Failed to connect to Monday.com');
    return false;
  }
}

// Get existing columns and create any missing ones
async function setupColumns() {
  setStatus('loading', 'Setting up board columns...');

  try {
    // Get current columns on the board
    const result = await mondayQuery(`{ boards(ids: [${BOARD_ID}]) { columns { id title type } } }`);
    const existingColumns = result.data.boards[0].columns;

    console.log('Existing columns:', existingColumns.map(c => `${c.title} (${c.id}, ${c.type})`));

    // Map existing columns to our required ones by matching title
    for (const req of REQUIRED_COLUMNS) {
      const match = existingColumns.find(c =>
        c.title.toLowerCase().replace(/[^a-z0-9]/g, '') === req.title.toLowerCase().replace(/[^a-z0-9]/g, '')
      );

      if (match) {
        BOARD_COLUMNS[req.key] = match.id;
        console.log(`Mapped "${req.title}" -> column ID: ${match.id}`);
      }
    }

    // Create any missing columns
    for (const req of REQUIRED_COLUMNS) {
      if (!BOARD_COLUMNS[req.key]) {
        console.log(`Creating column: "${req.title}" (${req.type})`);
        try {
          const createResult = await mondayQuery(`
            mutation {
              create_column(board_id: ${BOARD_ID}, title: "${req.title}", column_type: ${req.type}) {
                id
                title
              }
            }
          `);

          if (createResult.data && createResult.data.create_column) {
            BOARD_COLUMNS[req.key] = createResult.data.create_column.id;
            console.log(`Created "${req.title}" -> column ID: ${createResult.data.create_column.id}`);
          } else {
            console.warn(`Failed to create column "${req.title}":`, createResult);
          }
        } catch (colErr) {
          console.warn(`Error creating column "${req.title}":`, colErr);
        }
      }
    }

    boardReady = true;
    console.log('Board columns ready:', BOARD_COLUMNS);
    return true;

  } catch (err) {
    console.error('Error setting up columns:', err);
    setStatus('error', 'Failed to set up board columns');
    return false;
  }
}

// Create an item (row) on the Monday board for each supply item
async function createMondayItem(itemName, columnValues) {
  const colValsJson = JSON.stringify(JSON.stringify(columnValues));

  const mutation = `mutation {
    create_item(
      board_id: ${BOARD_ID},
      item_name: "${itemName.replace(/"/g, '\\"')}",
      column_values: ${colValsJson}
    ) {
      id
      name
    }
  }`;

  return mondayQuery(mutation);
}

// ==================== AUTH ====================
async function handleLogin(code) {
  if (OPERATORS[code]) {
    currentOperator = OPERATORS[code];
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('mainApp').style.display = 'block';
    document.getElementById('operatorName').textContent = currentOperator;

    // Set today's date as default
    document.getElementById('deliveryDate').valueAsDate = new Date();

    showToast('Hi ' + currentOperator + '!');

    // Auto-detect and setup Monday.com board
    const found = await findBoard();
    if (found) {
      await setupColumns();
      if (boardReady) {
        setStatus('idle', 'Connected to Monday.com - Ready to receive');
        showToast('Monday.com board connected!');
      }
    } else {
      // Still usable offline - will log locally
      setStatus('idle', 'Offline mode - Ready to receive (no Monday.com)');
    }
  }
}

function logout() {
  currentOperator = null;
  receiptItems = [];
  sessionReceipts = [];
  BOARD_ID = null;
  BOARD_COLUMNS = {};
  boardReady = false;
  document.getElementById('mainApp').style.display = 'none';
  document.getElementById('loginScreen').style.display = 'block';
  document.getElementById('codeInput').value = '';
  document.getElementById('codeInput').focus();
  switchTab('receive');
}

// ==================== SUPPLIER DROPDOWN ====================
document.getElementById('supplierName').addEventListener('change', function() {
  if (this.value === '__add_new__') {
    document.getElementById('newSupplierInput').style.display = 'block';
    document.getElementById('newSupplierActions').style.display = 'flex';
    document.getElementById('newSupplierInput').focus();
  }
});

function confirmNewSupplier() {
  const input = document.getElementById('newSupplierInput');
  const name = input.value.trim();
  if (!name) {
    showToast('Please enter a vendor name');
    input.focus();
    return;
  }

  const select = document.getElementById('supplierName');
  // Add new option before the "Add New" option
  const newOption = document.createElement('option');
  newOption.value = name;
  newOption.textContent = name;
  const addNewOption = select.querySelector('option[value="__add_new__"]');
  select.insertBefore(newOption, addNewOption);

  // Select the new vendor
  select.value = name;

  // Hide input
  input.value = '';
  input.style.display = 'none';
  document.getElementById('newSupplierActions').style.display = 'none';

  showToast(`Added vendor: ${name}`);
}

function cancelNewSupplier() {
  const select = document.getElementById('supplierName');
  select.value = '';
  document.getElementById('newSupplierInput').value = '';
  document.getElementById('newSupplierInput').style.display = 'none';
  document.getElementById('newSupplierActions').style.display = 'none';
}

document.getElementById('newSupplierInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') confirmNewSupplier();
  if (e.key === 'Escape') cancelNewSupplier();
});

// ==================== TABS ====================
function switchTab(tabName) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
  if (event && event.target) {
    event.target.classList.add('active');
  } else {
    document.querySelector('.tab-btn').classList.add('active');
  }
  document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));
  document.getElementById('tab-' + tabName).classList.add('active');
}

// ==================== ITEM MANAGEMENT ====================
function addItem() {
  const name = document.getElementById('itemName').value.trim();
  const qty = parseInt(document.getElementById('itemQty').value);
  const unit = document.getElementById('itemUnit').value;
  const condition = document.getElementById('itemCondition').value;
  const notes = document.getElementById('itemNotes').value.trim();

  if (!name) {
    showToast('Please enter an item name');
    document.getElementById('itemName').focus();
    return;
  }

  if (!qty || qty < 1) {
    showToast('Please enter a valid quantity');
    document.getElementById('itemQty').focus();
    return;
  }

  const item = {
    id: Date.now(),
    name: name,
    qty: qty,
    unit: unit,
    condition: condition,
    notes: notes,
    addedAt: new Date()
  };

  receiptItems.push(item);

  document.getElementById('itemName').value = '';
  document.getElementById('itemQty').value = '';
  document.getElementById('itemNotes').value = '';
  document.getElementById('itemCondition').value = 'good';
  document.getElementById('itemName').focus();

  renderItems();
  renderSummary();
  showToast(`Added: ${name} (${qty} ${unit})`);
}

function removeItem(itemId) {
  const item = receiptItems.find(i => i.id === itemId);
  receiptItems = receiptItems.filter(i => i.id !== itemId);
  renderItems();
  renderSummary();
  if (item) showToast(`Removed: ${item.name}`);
}

function renderItems() {
  const container = document.getElementById('itemsContainer');
  const countEl = document.getElementById('itemCount');
  const submitCard = document.getElementById('submitCard');

  countEl.textContent = `${receiptItems.length} item${receiptItems.length !== 1 ? 's' : ''}`;

  if (receiptItems.length === 0) {
    container.innerHTML = `
      <div class="empty-state" style="padding:20px;">
        <div class="empty-icon">&#128230;</div>
        <p>No items added yet. Add supply items above.</p>
      </div>`;
    submitCard.style.display = 'none';
    return;
  }

  submitCard.style.display = 'block';

  let html = '<ul class="items-list">';
  receiptItems.forEach((item, i) => {
    const conditionLabel = {
      'good': '&#9989; Good',
      'minor': '&#9888;&#65039; Minor Dmg',
      'damaged': '&#10060; Damaged',
      'rejected': '&#128683; Rejected'
    }[item.condition] || item.condition;

    html += `
      <li class="supply-item">
        <span class="item-number">${i + 1}</span>
        <div class="item-info">
          <span class="item-name">${escapeHtml(item.name)}</span>
          <span class="item-meta">${conditionLabel}${item.notes ? ' &middot; ' + escapeHtml(item.notes) : ''}</span>
        </div>
        <span class="item-qty">${item.qty} ${item.unit}</span>
        <button class="remove-btn" onclick="removeItem(${item.id})" title="Remove">&times;</button>
      </li>`;
  });
  html += '</ul>';
  container.innerHTML = html;
}

function renderSummary() {
  const container = document.getElementById('summaryContent');
  if (receiptItems.length === 0) {
    container.innerHTML = '';
    return;
  }

  const supplierVal = document.getElementById('supplierName').value;
  const supplier = (supplierVal && supplierVal !== '__add_new__') ? supplierVal : 'Not specified';
  const po = document.getElementById('poNumber').value.trim() || 'N/A';
  const date = document.getElementById('deliveryDate').value || 'Today';
  const method = document.getElementById('deliveryMethod').value || 'Not specified';
  const methodLabel = method || 'Not specified';

  const totalItems = receiptItems.reduce((sum, item) => sum + item.qty, 0);
  const damaged = receiptItems.filter(i => i.condition === 'damaged' || i.condition === 'rejected').length;

  container.innerHTML = `
    <div class="summary-row">
      <span class="summary-label">Supplier</span>
      <span class="summary-value">${escapeHtml(supplier)}</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">PO / Reference</span>
      <span class="summary-value">${escapeHtml(po)}</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Date</span>
      <span class="summary-value">${date}</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Delivery Method</span>
      <span class="summary-value">${methodLabel}</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Line Items</span>
      <span class="summary-value">${receiptItems.length}</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">Total Qty</span>
      <span class="summary-value highlight">${totalItems}</span>
    </div>
    ${damaged > 0 ? `<div class="summary-row">
      <span class="summary-label" style="color:var(--red);">&#9888; Damaged/Rejected</span>
      <span class="summary-value" style="color:var(--red);">${damaged} item${damaged !== 1 ? 's' : ''}</span>
    </div>` : ''}
    <div class="summary-row">
      <span class="summary-label">Monday.com</span>
      <span class="summary-value" style="font-size:13px;">${boardReady ? '&#9989; Will sync to Vital Supplies board' : '&#9888;&#65039; Offline - local log only'}</span>
    </div>`;
}

// ==================== SUBMIT RECEIPT ====================
function submitReceipt() {
  const supplier = document.getElementById('supplierName').value;
  if (!supplier || supplier === '__add_new__') {
    showToast('Please select a supplier');
    document.getElementById('supplierName').focus();
    window.scrollTo({ top: 0, behavior: 'smooth' });
    return;
  }

  if (receiptItems.length === 0) {
    showToast('Please add at least one item');
    return;
  }

  const modal = document.getElementById('confirmModal');
  const actions = document.getElementById('modalActions');
  const totalItems = receiptItems.reduce((sum, item) => sum + item.qty, 0);

  document.getElementById('modalTitle').textContent = 'Confirm Receipt';
  document.getElementById('modalText').textContent =
    `Log receipt of ${receiptItems.length} line item(s) (${totalItems} total units) from ${supplier}?` +
    (boardReady ? ' Items will be added to Monday.com.' : '');

  actions.innerHTML = `
    <button class="btn btn-green" onclick="confirmSubmit()">YES, Log Receipt</button>
    <button class="btn btn-small btn-outline" style="max-width:100%;" onclick="closeModal()">Cancel</button>`;

  modal.classList.add('active');
}

async function confirmSubmit() {
  closeModal();
  setStatus('loading', 'Logging receipt to Monday.com...');

  receiptCounter++;
  const receiptId = 'RCV-' + String(receiptCounter).padStart(4, '0');
  const supplier = document.getElementById('supplierName').value;
  const poNumber = document.getElementById('poNumber').value.trim();
  const deliveryDate = document.getElementById('deliveryDate').value;
  const deliveryMethod = document.getElementById('deliveryMethod').value;
  const methodLabel = deliveryMethod || '';

  const now = new Date();
  const receivedAt = now.toLocaleString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    hour: 'numeric', minute: '2-digit', hour12: true
  });

  const conditionLabels = {
    'good': 'Good',
    'minor': 'Minor Damage',
    'damaged': 'Damaged',
    'rejected': 'Rejected'
  };

  // Push each item as a row to Monday.com
  let mondaySuccess = 0;
  let mondayErrors = 0;

  if (boardReady) {
    for (let i = 0; i < receiptItems.length; i++) {
      const item = receiptItems[i];
      setStatus('loading', `Sending item ${i + 1} of ${receiptItems.length} to Monday.com...`);

      try {
        // Build column values object
        const columnValues = {};

        if (BOARD_COLUMNS.supplier)        columnValues[BOARD_COLUMNS.supplier] = supplier;
        if (BOARD_COLUMNS.po_number)       columnValues[BOARD_COLUMNS.po_number] = poNumber;
        if (BOARD_COLUMNS.delivery_date)   columnValues[BOARD_COLUMNS.delivery_date] = { date: deliveryDate };
        if (BOARD_COLUMNS.delivery_method) columnValues[BOARD_COLUMNS.delivery_method] = methodLabel;
        if (BOARD_COLUMNS.quantity)        columnValues[BOARD_COLUMNS.quantity] = item.qty;
        if (BOARD_COLUMNS.unit)            columnValues[BOARD_COLUMNS.unit] = item.unit;
        if (BOARD_COLUMNS.condition)       columnValues[BOARD_COLUMNS.condition] = { label: conditionLabels[item.condition] || item.condition };
        if (BOARD_COLUMNS.notes)           columnValues[BOARD_COLUMNS.notes] = { text: item.notes || '' };
        if (BOARD_COLUMNS.received_by)     columnValues[BOARD_COLUMNS.received_by] = currentOperator;
        if (BOARD_COLUMNS.received_at)     columnValues[BOARD_COLUMNS.received_at] = receivedAt;
        if (BOARD_COLUMNS.receipt_id)      columnValues[BOARD_COLUMNS.receipt_id] = receiptId;

        const result = await createMondayItem(item.name, columnValues);

        if (result.data && result.data.create_item) {
          mondaySuccess++;
          console.log(`Item "${item.name}" created on Monday.com (ID: ${result.data.create_item.id})`);
        } else {
          mondayErrors++;
          console.error(`Failed to create item "${item.name}":`, result);
        }
      } catch (err) {
        mondayErrors++;
        console.error(`Error creating item "${item.name}":`, err);
      }
    }
  }

  // Build local receipt record
  const receipt = {
    id: receiptId,
    operator: currentOperator,
    supplier: supplier,
    poNumber: poNumber,
    deliveryDate: deliveryDate,
    deliveryMethod: deliveryMethod,
    items: [...receiptItems],
    totalQty: receiptItems.reduce((sum, item) => sum + item.qty, 0),
    lineItems: receiptItems.length,
    hasDamaged: receiptItems.some(i => i.condition === 'damaged' || i.condition === 'rejected'),
    loggedAt: now,
    mondaySynced: mondaySuccess,
    mondayErrors: mondayErrors
  };

  sessionReceipts.unshift(receipt);

  // Clear form
  receiptItems = [];
  document.getElementById('supplierName').value = '';
  document.getElementById('poNumber').value = '';
  document.getElementById('deliveryDate').valueAsDate = new Date();
  document.getElementById('deliveryMethod').value = '';

  renderItems();
  renderSummary();
  renderLog();

  if (boardReady && mondayErrors === 0) {
    setStatus('success', `${receipt.id} logged - ${mondaySuccess} item(s) synced to Monday.com`);
    showToast(`Receipt ${receipt.id} synced to Monday.com!`);
  } else if (boardReady && mondayErrors > 0) {
    setStatus('error', `${receipt.id} logged - ${mondayErrors} item(s) failed to sync`);
    showToast(`Receipt logged with ${mondayErrors} sync error(s)`);
  } else {
    setStatus('success', `${receipt.id} logged locally`);
    showToast(`Receipt ${receipt.id} logged (offline)`);
  }

  setTimeout(() => {
    setStatus('idle', boardReady ? 'Connected to Monday.com - Ready to receive' : 'Ready to receive supplies');
  }, 4000);
}

function closeModal() {
  document.getElementById('confirmModal').classList.remove('active');
}

// ==================== LOG RENDERING ====================
function renderLog() {
  const container = document.getElementById('logContainer');
  const countEl = document.getElementById('logCount');

  countEl.textContent = `${sessionReceipts.length} receipt${sessionReceipts.length !== 1 ? 's' : ''} this session`;

  if (sessionReceipts.length === 0) {
    container.innerHTML = `
      <div class="empty-state" style="padding:20px;">
        <p>No receipts logged this session</p>
      </div>`;
    return;
  }

  let html = `<table class="log-table">
    <thead>
      <tr>
        <th>Receipt #</th>
        <th>Supplier</th>
        <th>Items</th>
        <th>Total Qty</th>
        <th>Time</th>
        <th>Monday.com</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>`;

  sessionReceipts.forEach(r => {
    const statusClass = r.hasDamaged ? 'partial' : 'received';
    const statusText = r.hasDamaged ? 'Has Issues' : 'Received';
    const syncStatus = r.mondaySynced > 0
      ? `<span class="status-badge received">${r.mondaySynced} synced</span>`
      : '<span style="font-size:11px;color:var(--text-muted);">-</span>';

    html += `
      <tr>
        <td><strong>${r.id}</strong></td>
        <td>${escapeHtml(r.supplier)}</td>
        <td>${r.lineItems}</td>
        <td>${r.totalQty}</td>
        <td>${formatTime(r.loggedAt)}</td>
        <td>${syncStatus}</td>
        <td><span class="status-badge ${statusClass}">${statusText}</span></td>
      </tr>`;
  });

  html += '</tbody></table>';
  container.innerHTML = html;
}

// ==================== HELPERS ====================
function setStatus(type, msg) {
  const bar = document.getElementById('statusBar');
  bar.className = `status-bar ${type}`;
  bar.innerHTML = type === 'loading'
    ? `<div class="spinner"></div><span>${msg}</span>`
    : `<span>${msg}</span>`;
}

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 3000);
}

function formatTime(date) {
  if (!date) return '';
  return date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
}

function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// ==================== INIT ====================
document.getElementById('codeInput').addEventListener('input', function(e) {
  if (e.target.value.length === 4) {
    handleLogin(e.target.value);
  }
});

document.getElementById('codeInput').addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && e.target.value.length >= 2) {
    handleLogin(e.target.value);
  }
});

document.getElementById('itemQty').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') addItem();
});

document.getElementById('itemName').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') document.getElementById('itemQty').focus();
});
